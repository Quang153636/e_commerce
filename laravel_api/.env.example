APP_NAME="Ecommerce API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecommerce
DB_USERNAME=root
DB_PASSWORD=

SANCTUM_STATEFUL_DOMAINS=localhost
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

FILESYSTEM_DISK=public

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# Dùng cho mô-đun theo dõi vị trí đơn hàng trên bản đồ (Flutter dùng Google Maps / OSM)
DEFAULT_LAT=21.0285
DEFAULT_LNG=105.8542
